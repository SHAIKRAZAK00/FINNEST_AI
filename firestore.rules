
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isFamilyMember(familyId) { return isSignedIn() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)); }
    function getUserRole(familyId) { return get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role; }
    function isFamilyParent(familyId) { return isFamilyMember(familyId) && getUserRole(familyId) == 'Parent'; }
    function isFamilyContributor(familyId) { return isFamilyMember(familyId) && (getUserRole(familyId) == 'Parent' || getUserRole(familyId) == 'Child'); }

    match /families/{familyId} {
      allow get: if isFamilyMember(familyId);
      allow list: if isSignedIn(); // Necessary for "Join by Code" query
      allow create: if isSignedIn();
      allow update: if isFamilyParent(familyId);

      match /members/{userId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isFamilyParent(familyId);
        allow delete: if isOwner(userId) || isFamilyParent(familyId);
      }

      match /expenses/{expenseId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyContributor(familyId);
        allow update, delete: if isFamilyContributor(familyId);
      }

      match /goals/{goalId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyContributor(familyId);
        allow update, delete: if isFamilyContributor(familyId);
      }

      match /gamification/{userId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }
    }
  }
}
