
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check if a user is a member of a family.
    function isMember(familyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isParent(familyId) {
      return isMember(familyId) && get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'Parent';
    }

    // --- GLOBAL USER DIRECTORY ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // --- FAMILY COLLECTION RULES ---
    match /families/{familyId} {
      // allow list for family discovery by code.
      allow list: if isSignedIn();
      allow get: if isMember(familyId) || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId);
      
      allow create: if isSignedIn();
      allow update: if isParent(familyId);
      allow delete: if isParent(familyId);

      match /members/{userId} {
        allow get, list: if isMember(familyId) || isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId) || isParent(familyId);
      }

      match /expenses/{expenseId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId);
        allow update, delete: if isParent(familyId) || (resource != null && isOwner(resource.data.contributorId));
      }

      match /goals/{goalId} {
        allow read: if isMember(familyId);
        allow create, update: if isMember(familyId);
        allow delete: if isParent(familyId);
      }

      match /allowances/{userId} {
        allow get: if isOwner(userId) || isParent(familyId);
        allow create, update, delete: if isParent(familyId);
      }

      match /trustMetrics/{userId} {
        allow read: if isOwner(userId) || isParent(familyId);
        allow write: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
