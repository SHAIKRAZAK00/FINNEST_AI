
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOf(dataMap) {
      return isSignedIn() && (request.auth.uid in dataMap);
    }

    function hasRole(dataMap, role) {
      return isMemberOf(dataMap) && dataMap[request.auth.uid].role == role;
    }

    function isParent(dataMap) {
      return hasRole(dataMap, 'Parent');
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- GLOBAL USER DIRECTORY ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // --- FAMILY COLLECTION RULES ---
    match /families/{familyId} {
      allow get: if isMemberOf(resource.data.members);
      allow list: if isSignedIn() && isMemberOf(resource.data.members);
      allow create: if isSignedIn() && request.resource.data.id == familyId;
      allow update: if resource != null && isParent(resource.data.members);
      allow delete: if resource != null && isParent(resource.data.members);

      match /members/{userId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow delete: if isOwner(userId) || isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members);
      }

      match /expenses/{expenseId} {
        allow read: if isMemberOf(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow create: if isMemberOf(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow update, delete: if isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members) || isOwner(resource.data.contributorId);
      }

      match /goals/{goalId} {
        allow read: if isMemberOf(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow create, update: if isMemberOf(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow delete: if isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members);
      }

      match /allowances/{userId} {
        allow get: if isOwner(userId) || isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow create, update, delete: if isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members);
      }

      match /trustMetrics/{userId} {
        allow read: if isOwner(userId) || isParent(get(/databases/$(database)/documents/families/$(familyId)).data.members);
        allow write: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
