{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the FinNest AI application.",
      "properties": {
        "name": {
          "type": "string",
          "description": "User's full name."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL for the user's profile picture."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family document ID."
        },
        "role": {
          "type": "string",
          "description": "User's role within the family (Parent, Child, Viewer)."
        }
      },
      "required": [
        "name",
        "email",
        "role",
        "familyId"
      ]
    },
    "Family": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Family",
      "type": "object",
      "description": "Represents a family group within the FinNest AI application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the family."
        },
        "familyName": {
          "type": "string",
          "description": "Name of the family."
        },
        "createdBy": {
          "type": "string",
          "description": "Reference to User who created the family. (Relationship: User 1:N Family)"
        },
        "familyCode": {
          "type": "string",
          "description": "Unique code for joining the family."
        }
      },
      "required": [
        "id",
        "familyName",
        "createdBy",
        "familyCode"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents an expense recorded within a family.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the expense."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family. (Relationship: Family 1:N Expense)"
        },
        "category": {
          "type": "string",
          "description": "Category of the expense."
        },
        "amount": {
          "type": "number",
          "description": "Amount of the expense."
        },
        "contributorId": {
          "type": "string",
          "description": "Reference to User who contributed to the expense. (Relationship: User 1:N Expense)"
        },
        "date": {
          "type": "string",
          "description": "Date of the expense.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "familyId",
        "category",
        "amount",
        "contributorId",
        "date"
      ]
    },
    "Goal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Goal",
      "type": "object",
      "description": "Represents a financial goal set by a family.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the goal."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family. (Relationship: Family 1:N Goal)"
        },
        "name": {
          "type": "string",
          "description": "Name of the goal."
        },
        "targetAmount": {
          "type": "number",
          "description": "Target amount for the goal."
        },
        "currentAmount": {
          "type": "number",
          "description": "Current amount saved towards the goal."
        },
        "contributorIds": {
          "type": "array",
          "description": "References to Users contributing to the goal. (Relationship: User N:N Goal)",
          "items": {
            "type": "string"
          }
        },
        "endDate": {
          "type": "string",
          "description": "End date for the goal.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "familyId",
        "name",
        "targetAmount",
        "currentAmount",
        "endDate"
      ]
    },
    "Insight": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Insight",
      "type": "object",
      "description": "Represents a financial insight generated by the AI CFO assistant.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the insight."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family. (Relationship: Family 1:N Insight)"
        },
        "insightText": {
          "type": "string",
          "description": "The insight text generated by the AI."
        },
        "date": {
          "type": "string",
          "description": "Date when the insight was generated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "familyId",
        "insightText",
        "date"
      ]
    },
    "Gamification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Gamification",
      "type": "object",
      "description": "Represents a user's gamification data.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:1 Gamification)"
        },
        "points": {
          "type": "number",
          "description": "Number of points the user has earned."
        },
        "level": {
          "type": "number",
          "description": "Current level of the user."
        },
        "badges": {
          "type": "array",
          "description": "List of badges earned by the user.",
          "items": {
            "type": "string"
          }
        },
        "savingStreaks": {
          "type": "number",
          "description": "Saving Streaks of User"
        }
      },
      "required": [
        "userId",
        "points",
        "level",
        "badges",
        "savingStreaks"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/families/{familyId}",
        "definition": {
          "entityName": "Family",
          "schema": {
            "$ref": "#/backend/entities/Family"
          },
          "description": "Stores family metadata.  Root for all family-related data.",
          "params": [
            {
              "name": "familyId",
              "description": "Unique identifier for the family."
            }
          ]
        }
      },
      {
        "path": "/families/{familyId}/members/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user role and connection details within a family. Includes 'role' field for role-based access control.",
          "params": [
            {
              "name": "familyId",
              "description": "Unique identifier for the family."
            },
            {
              "name": "userId",
              "description": "Unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "/families/{familyId}/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Stores expense data for a family. Includes denormalized 'familyId' for authorization independence.",
          "params": [
            {
              "name": "familyId",
              "description": "Unique identifier for the family."
            },
            {
              "name": "expenseId",
              "description": "Unique identifier for the expense."
            }
          ]
        }
      },
      {
        "path": "/families/{familyId}/goals/{goalId}",
        "definition": {
          "entityName": "Goal",
          "schema": {
            "$ref": "#/backend/entities/Goal"
          },
          "description": "Stores financial goal data for a family. Includes denormalized 'familyId' for authorization independence.",
          "params": [
            {
              "name": "familyId",
              "description": "Unique identifier for the family."
            },
            {
              "name": "goalId",
              "description": "Unique identifier for the goal."
            }
          ]
        }
      },
      {
        "path": "/families/{familyId}/insights/{insightId}",
        "definition": {
          "entityName": "Insight",
          "schema": {
            "$ref": "#/backend/entities/Insight"
          },
          "description": "Stores AI-generated financial insights for a family. Includes denormalized 'familyId' for authorization independence.",
          "params": [
            {
              "name": "familyId",
              "description": "Unique identifier for the family."
            },
            {
              "name": "insightId",
              "description": "Unique identifier for the insight."
            }
          ]
        }
      },
      {
        "path": "/families/{familyId}/gamification/{userId}",
        "definition": {
          "entityName": "Gamification",
          "schema": {
            "$ref": "#/backend/entities/Gamification"
          },
          "description": "Stores gamification data for a user within a family. Uses path-based ownership.",
          "params": [
            {
              "name": "familyId",
              "description": "Unique identifier for the family."
            },
            {
              "name": "userId",
              "description": "Unique identifier for the user."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore data structure is designed to facilitate a secure and collaborative family finance ecosystem. The design prioritizes authorization independence by denormalizing family membership information onto the child collections (Expenses, Goals, Insights). This approach eliminates the need for `get()` calls in security rules, enabling atomic operations and improving scalability and security. The use of family-scoped collections (e.g., `/families/{familyId}/expenses/{expenseId}`) ensures that data access is restricted to family members only, with role-based access control (Parent, Child, Viewer) enforced via Firebase Security Rules. Path-based ownership is utilized for User-owned data within the family context (Gamification). This structure enables efficient `list` operations (QAPs) by leveraging collection-based access control, ensuring that only authorized family members can access the data.  The `families` collection holds family metadata and acts as the root for all family-related data.  User roles are stored directly in the `/families/{familyId}/members/{userId}` document, making role assignments explicit. The structure also supports integrity of data by enforcing strong type checking through schema definitions and explicit state modeling."
  }
}
    