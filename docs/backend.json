
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the FinNest AI application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string" },
        "familyId": { "type": "string" },
        "role": { "type": "string", "enum": ["Parent", "Child", "Viewer"] },
        "badges": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role", "familyId"]
    },
    "Family": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Family",
      "type": "object",
      "description": "Represents a family group.",
      "properties": {
        "id": { "type": "string" },
        "familyName": { "type": "string" },
        "createdBy": { "type": "string" },
        "familyCode": { "type": "string" }
      },
      "required": ["id", "familyName", "createdBy", "familyCode"]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "familyId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "contributorId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "familyId", "category", "amount", "description", "contributorId", "date"]
    },
    "Goal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "familyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "contributors": { "type": "array", "items": { "type": "string" } },
        "deadline": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "familyId", "name", "targetAmount", "currentAmount", "contributors", "deadline"]
    },
    "Gamification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Gamification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "familyId": { "type": "string" },
        "points": { "type": "number" },
        "level": { "type": "number" },
        "savingStreaks": { "type": "number" }
      },
      "required": ["userId", "familyId", "points", "level"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "families/{familyId}": {
      "schema": "#/entities/Family",
      "description": "Family metadata."
    },
    "families/{familyId}/members/{userId}": {
      "schema": "#/entities/User",
      "description": "Member details."
    },
    "families/{familyId}/expenses/{expenseId}": {
      "schema": "#/entities/Expense",
      "description": "Expense data."
    },
    "families/{familyId}/goals/{goalId}": {
      "schema": "#/entities/Goal",
      "description": "Financial goals."
    },
    "families/{familyId}/gamification/{userId}": {
      "schema": "#/entities/Gamification",
      "description": "Gamification points."
    }
  }
}
