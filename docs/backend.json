
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the FinNest AI application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string" },
        "familyId": { "type": "string" },
        "role": { "type": "string", "enum": ["Parent", "Child", "Viewer"] },
        "points": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "financialPersonality": { "type": "string" },
        "personalityLastUpdated": { "type": "string" },
        "learning": {
          "type": "object",
          "properties": {
            "completedQuizzes": { "type": "array", "items": { "type": "string" } },
            "missionProgress": { "type": "object" },
            "unlockedRewards": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["id", "name", "email", "role", "familyId"]
    },
    "Family": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Family",
      "type": "object",
      "description": "Represents a family group.",
      "properties": {
        "id": { "type": "string" },
        "familyName": { "type": "string" },
        "createdBy": { "type": "string" },
        "familyCode": { "type": "string" },
        "monthlyBudget": { "type": "number" },
        "currentMonthSpent": { "type": "number" },
        "budgetMonth": { "type": "string" }
      },
      "required": ["id", "familyName", "createdBy", "familyCode"]
    },
    "TrustMetric": {
      "type": "object",
      "properties": {
        "overallTrustScore": { "type": "number" },
        "contributionScore": { "type": "number" },
        "disciplineScore": { "type": "number" },
        "updatedAt": { "type": "string" }
      }
    },
    "Allowance": {
      "type": "object",
      "properties": {
        "total": { "type": "number" },
        "saved": { "type": "number" },
        "childId": { "type": "string" }
      }
    },
    "Report": {
      "type": "object",
      "properties": {
        "monthId": { "type": "string" },
        "summary": { "type": "string" },
        "topContributor": { "type": "string" },
        "data": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "families/{familyId}": {
      "schema": "#/entities/Family",
      "description": "Family metadata."
    },
    "families/{familyId}/members/{userId}": {
      "schema": "#/entities/User",
      "description": "Member details."
    },
    "families/{familyId}/trustMetrics/{userId}": {
      "schema": "#/entities/TrustMetric",
      "description": "Financial trust transparency scores."
    },
    "families/{familyId}/allowances/{userId}": {
      "schema": "#/entities/Allowance",
      "description": "Virtual allowance for children."
    },
    "families/{familyId}/reports/{reportId}": {
      "schema": "#/entities/Report",
      "description": "Monthly financial reports."
    }
  }
}
