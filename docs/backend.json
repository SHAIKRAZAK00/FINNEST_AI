
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the FinNest AI application.",
      "properties": {
        "name": {
          "type": "string",
          "description": "User's full name."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL for the user's profile picture."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family document ID."
        },
        "role": {
          "type": "string",
          "description": "User's role within the family (Parent, Child, Viewer)."
        }
      },
      "required": [
        "name",
        "email",
        "role",
        "familyId"
      ]
    },
    "Family": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Family",
      "type": "object",
      "description": "Represents a family group within the FinNest AI application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the family."
        },
        "familyName": {
          "type": "string",
          "description": "Name of the family."
        },
        "createdBy": {
          "type": "string",
          "description": "Reference to User who created the family."
        },
        "familyCode": {
          "type": "string",
          "description": "Unique code for joining the family."
        }
      },
      "required": [
        "id",
        "familyName",
        "createdBy",
        "familyCode"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents an expense recorded within a family.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the expense."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family."
        },
        "category": {
          "type": "string",
          "description": "Category of the expense."
        },
        "amount": {
          "type": "number",
          "description": "Amount of the expense."
        },
        "description": {
          "type": "string",
          "description": "Brief description of the expense."
        },
        "contributorId": {
          "type": "string",
          "description": "Reference to User who contributed to the expense."
        },
        "date": {
          "type": "string",
          "description": "Date of the expense.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "familyId",
        "category",
        "amount",
        "description",
        "contributorId",
        "date"
      ]
    },
    "Goal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Goal",
      "type": "object",
      "description": "Represents a financial goal set by a family.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the goal."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family."
        },
        "name": {
          "type": "string",
          "description": "Name of the goal."
        },
        "description": {
          "type": "string",
          "description": "A short description of the goal."
        },
        "targetAmount": {
          "type": "number",
          "description": "Target amount for the goal."
        },
        "currentAmount": {
          "type": "number",
          "description": "Current amount saved towards the goal."
        },
        "contributors": {
          "type": "array",
          "description": "References to Users contributing to the goal.",
          "items": {
            "type": "string"
          }
        },
        "deadline": {
          "type": "string",
          "description": "Deadline for the goal.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "familyId",
        "name",
        "description",
        "targetAmount",
        "currentAmount",
        "contributors",
        "deadline"
      ]
    },
    "Insight": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Insight",
      "type": "object",
      "description": "Represents a financial insight generated by the AI assistant.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the insight."
        },
        "familyId": {
          "type": "string",
          "description": "Reference to Family."
        },
        "insightText": {
          "type": "string",
          "description": "The insight text generated by the AI."
        },
        "date": {
          "type": "string",
          "description": "Date when the insight was generated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "familyId",
        "insightText",
        "date"
      ]
    },
    "Gamification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Gamification",
      "type": "object",
      "description": "Represents a user's gamification data.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to User."
        },
        "points": {
          "type": "number",
          "description": "Number of points the user has earned."
        },
        "level": {
          "type": "number",
          "description": "Current level of the user."
        },
        "badges": {
          "type": "array",
          "description": "List of badges earned by the user.",
          "items": {
            "type": "string"
          }
        },
        "savingStreaks": {
          "type": "number",
          "description": "Saving Streaks of User"
        }
      },
      "required": [
        "userId",
        "points",
        "level",
        "badges",
        "savingStreaks"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "families/{familyId}": {
      "schema": "#/entities/Family",
      "description": "Stores family metadata."
    },
    "families/{familyId}/members/{userId}": {
      "schema": "#/entities/User",
      "description": "Stores user details within a family."
    },
    "families/{familyId}/expenses/{expenseId}": {
      "schema": "#/entities/Expense",
      "description": "Stores expense data for a family."
    },
    "families/{familyId}/goals/{goalId}": {
      "schema": "#/entities/Goal",
      "description": "Stores financial goal data for a family."
    },
    "families/{familyId}/insights/{insightId}": {
      "schema": "#/entities/Insight",
      "description": "Stores AI-generated financial insights."
    },
    "families/{familyId}/gamification/{userId}": {
      "schema": "#/entities/Gamification",
      "description": "Stores gamification data for a user."
    }
  }
}
